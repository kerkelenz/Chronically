{
  "expo": {
    "name": "Chronically",
    "slug": "chronically-mobile",
    "scheme": "chronically",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.chronically.chronicallymobile",
      "supportsTablet": true,
      "infoPlist": {
        "UIFileSharingEnabled": true,
        "LSSupportsOpeningDocumentsInPlace": true,
        "NSPhotoLibraryUsageDescription": "Chronically uses your photo library so you can choose a profile picture."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#7C6BAE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.chronically.chronicallymobile"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "react-native-edge-to-edge",
        { "android": { "enforceNavigationBarContrast": false } }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9362e50f-8877-448a-99f9-de8eeff0a432"
      }
    }
  }
}
